# Root environment values used by apps/services.
# Copy values into service-specific env files as needed.

# API / Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_ACCESS_SECRET=replace_with_secure_secret
JWT_REFRESH_SECRET=replace_with_secure_secret

# Google OAuth
GOOGLE_CLIENT_ID=replace_with_google_client_id

# Mail (OTP)
MAILJET_API_KEY=replace_with_mailjet_api_key
MAILJET_API_SECRET=replace_with_mailjet_api_secret
MAILJET_FROM_EMAIL=hello@example.com
MAILJET_FROM_NAME=Vouch

# AI + Cache
GEMINI_API_KEY=replace_with_gemini_api_key
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace_with_upstash_token

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=replace_with_google_client_id

# Extension
VITE_API_URL=http://localhost:5173